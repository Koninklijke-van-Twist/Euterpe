# Euterpe systemd environment
# Kopieer naar /etc/euterpe/env (install-service.sh doet dit automatisch)

# EUTERPE_PORT=8000
# EUTERPE_EXTRA_PORTS=80
# EUTERPE_PORTS=8000,80
# EUTERPE_DATA_DIR=/opt/euterpe/data
# EUTERPE_MPV_PATH=mpv        # Arch/Linux
# EUTERPE_MPV_PATH=mpvnet     # Windows
# EUTERPE_MPV_AO=alsa         # Linux server: vermijdt PipeWire-fouten onder systemd (standaard op Linux)
# EUTERPE_MPV_AO=             # mpv kiest zelf (desktop met PipeWire)
# EUTERPE_MPV_EXTRA_ARGS=--audio-device=alsa/default

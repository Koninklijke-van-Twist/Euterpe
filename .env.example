# Lokale dev-config (kopieer naar .env)
# Wordt automatisch geladen bij start — geen extra packages nodig

# Windows (mpvnet in PATH):
EUTERPE_MPV_PATH=mpvnet
# Sluit andere mpv.net-vensters vóór start — Euterpe start een eigen instantie.
# Bij problemen: volledig pad, of plain mpv installeren (scoop/choco) en EUTERPE_MPV_PATH=mpv
# EUTERPE_MPV_PATH=C:\Tools\mpv.net\mpvnet.exe

# Linux / Arch productie:
# EUTERPE_MPV_PATH=mpv

# EUTERPE_PORT=8000
# Extra poorten (komma-gescheiden), of alles in één regel:
# EUTERPE_EXTRA_PORTS=80
# EUTERPE_PORTS=8000,80
# Poort 80 vereist op Windows/Linux vaak admin/root-rechten.
